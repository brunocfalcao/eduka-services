{
    "name": "brunocfalcao/eduka-services",
    "description": "Model service extensions to implement Eduka business logic",
    "keywords": [
        "brunocfalcao",
        "eduka"
    ],
    "homepage": "https://github.com/brunocfalcao/eduka-services",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Bruno Falcão",
            "email": "bruno.c.falcao@brunofalcao.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Eduka\\Services\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eduka\\Services\\EdukaServicesServiceProvider"
            ]
        }
    }
}
